@page "/"
@inject TinyUrl.Blazor.Services.UrlService UrlService
@inject IJSRuntime JS

@if (!isReady)
{
    <div class="loading-screen">
        <div class="spinner"></div>
        <p>Connecting...</p>
    </div>
}
else
{
    <div class="container">
        <h1>🔗 Tiny URL</h1>

        <div class="card">
            <div class="form-row">
                <div class="input-wrapper">
                    <input value="@longUrl"
                           @oninput="OnUrlInput"
                           placeholder="Enter URL to shorten..."
                           class="url-input @(string.IsNullOrEmpty(urlError) ? "" : "input-error")" />
                    @if (!string.IsNullOrEmpty(urlError))
                    {
                        <span class="validation-error">⚠️ @urlError</span>
                    }
                </div>
                <label class="checkbox-label">
                    <input type="checkbox" @bind="isPrivate" /> Private
                </label>
                <button @onclick="Generate"
                        class="btn-primary"
                        disabled="@(!string.IsNullOrEmpty(urlError))">
                    Generate
                </button>
            </div>

            @if (!string.IsNullOrEmpty(generatedUrl))
            {
                <div class="result-box">
                    <a href="@generatedUrl" target="_blank">
                        @generatedUrl
                    </a>
                    <button @onclick="() => Copy(generatedUrl)"
                            class="btn-copy">
                        @(copied ? "✅ Copied!" : "📋 Copy")
                    </button>
                </div>
            }

            @if (!string.IsNullOrEmpty(error))
            {
                <p class="error">@error</p>
            }
        </div>

        <div class="card">
            <h2>Public URLs</h2>
            <input value="@search"
                   @oninput="OnSearch"
                   placeholder="Search..."
                   class="search-input" />

            @if (loading)
            {
                <div class="empty">Loading...</div>
            }
            else if (urls.Count == 0)
            {
                <div class="empty">No URLs found.</div>
            }
            else
            {
                @foreach (var u in urls)
                {
                    <div class="url-card">
                        <div class="url-info">
                            <a href="@u.ShortUrl"
                                   target="_blank"
                                   class="short-link">
                                /@u.ShortCode
                            </a>
                            <span class="original">@u.OriginalUrl</span>
                        </div>
                        <div class="url-actions">
                            <span class="clicks">@u.Clicks clicks</span>
                            <button @onclick="() => Copy(u.ShortUrl)"
                                    class="btn-copy">
                                📋 Copy
                            </button>
                            <button @onclick="() => Delete(u.ShortCode)"
                                    class="btn-danger">
                                🗑 Delete
                            </button>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
}

@code {
    private string longUrl = "";
    private bool isPrivate = false;
    private List<TinyUrl.Blazor.Models.TinyUrlEntry> urls = new();
    private string search = "";
    private string generatedUrl = "";
    private bool copied = false;
    private string error = "";
    private string urlError = "";
    private bool loading = false;
    private bool isReady = false;

    protected override async Task OnInitializedAsync()
    {
        // ✅ Auto login on start
        await AutoLogin();
        await Load();
    }

    private async Task AutoLogin()
    {
        try
        {
            var result = await UrlService.AutoLoginAsync();
            if (result != null)
            {
                isReady = true;
                // Auto refresh before expiry
                var refreshMs = (result.ExpiresIn - 60) * 1000;
                _ = Task.Delay(refreshMs)
                    .ContinueWith(async _ => await AutoLogin());
            }
            else
            {
                isReady = true;
            }
        }
        catch
        {
            isReady = true;
        }
    }

    private string ValidateUrl(string url)
    {
        if (string.IsNullOrWhiteSpace(url))
            return "URL is required";

        var testUrl = url.Trim();
        if (!testUrl.StartsWith("http://") &&
            !testUrl.StartsWith("https://"))
            testUrl = "https://" + testUrl;

        if (!Uri.TryCreate(testUrl, UriKind.Absolute, out var uri))
            return "Invalid URL — please enter a valid web address";

        if (uri.Scheme != "http" && uri.Scheme != "https")
            return "Invalid URL — must start with http or https";

        if (!uri.Host.Contains('.'))
            return "Invalid URL — must include domain";

        if (url.Contains(' '))
            return "URL cannot contain spaces";

        return "";
    }

    private void OnUrlInput(ChangeEventArgs e)
    {
        longUrl = e.Value?.ToString() ?? "";
        urlError = ValidateUrl(longUrl);
    }

    private async Task Load()
    {
        try
        {
            loading = true;
            urls = await UrlService.GetPublicAsync(search);
            error = "";
        }
        catch
        {
            if (urls.Count == 0)
                error = "Failed to load URLs";
        }
        finally
        {
            loading = false;
        }
    }

    private async Task Generate()
    {
        urlError = ValidateUrl(longUrl);
        if (!string.IsNullOrEmpty(urlError)) return;

        try
        {
            error = "";
            var result = await UrlService.AddAsync(longUrl, isPrivate);
            if (result != null)
            {
                generatedUrl = result.ShortUrl;
                longUrl = "";
                urlError = "";
                await Load();
            }
        }
        catch
        {
            error = "Failed to generate URL";
        }
    }

    private async Task Delete(string code)
    {
        await UrlService.DeleteAsync(code);
        await Load();
    }

    private async Task Copy(string text)
    {
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", text);
        copied = true;
        await Task.Delay(2000);
        copied = false;
        StateHasChanged();
    }

    private async Task OnSearch(ChangeEventArgs e)
    {
        search = e.Value?.ToString() ?? "";
        await Load();
    }
}